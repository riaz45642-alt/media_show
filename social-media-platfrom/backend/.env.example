PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/safezone
JWT_SECRET=change_this_secret
CLIENT_URL=http://localhost:5173

# --- Content moderation (hybrid pipeline) ---
# Get a free key at https://aistudio.google.com/apikey. If left unset, the AI
# layer is skipped gracefully and moderation runs on rule-based filtering
# alone (still blocks injection/spam/banned-keyword content; just loses the
# context-aware AI scoring, so add a key before going to production).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
